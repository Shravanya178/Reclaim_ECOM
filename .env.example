# Copy this file to .env.json and fill in your values.
# Used with: flutter run --dart-define-from-file=.env.json
# Or:        flutter build web --dart-define-from-file=.env.json

{
  "RAZORPAY_KEY_ID": "rzp_test_XXXXXXXXXXXXXX",
  "RAZORPAY_KEY_SECRET": "XXXXXXXXXXXXXXXXXXXXXXXXXX"
}

# ⚠️  RAZORPAY_KEY_SECRET is NEVER sent to the browser.
#     It is only referenced in AppConfig for server-side signature
#     verification (backend / Cloud Function).
#     The browser only receives RAZORPAY_KEY_ID.
